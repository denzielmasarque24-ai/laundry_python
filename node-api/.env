# Resend SMTP
EMAIL_USER=onboarding@resend.dev
EMAIL_PASS=your_actual_key_here
MAIL_SERVER=smtp.resend.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_FROM=onboarding@resend.dev

# Database
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=freshwash
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=freshwash_secret_key

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
ENABLE_LOGIN_OTP=true
